{
  "name": "@kjanat/prettier-config",
  "version": "1.1.2",
  "type": "module",
  "description": "Yet another Prettier config",
  "repository": "github:kjanat/prettier-config",
  "homepage": "https://github.com/kjanat/prettier-config#readme",
  "bugs": {
    "url": "https://github.com/kjanat/prettier-config/issues"
  },
  "author": "Kaj Kowalski <dev@kajkowalski.nl> (https://github.com/kjanat)",
  "license": "MIT",
  "packageManager": "bun@1.3.14",
  "main": "./build/prettier.config.mjs",
  "types": "./build/prettier.config.d.mts",
  "exports": {
    ".": {
      "types": "./build/prettier.config.d.mts",
      "default": "./build/prettier.config.mjs"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "build/",
    "prettier.config.ts",
    "README.md",
    "LICENSE"
  ],
  "keywords": [
    "prettier-config"
  ],
  "scripts": {
    "build": "tsdown",
    "format": "prettier . --write",
    "postinstall": "lefthook install",
    "prepare": "bun run build",
    "prepublishOnly": "bun typecheck && bun run build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "@prettier/plugin-xml": "^3.4.2",
    "prettier-plugin-go-template": "^0.0.15",
    "prettier-plugin-nginx": "^1.0.3",
    "prettier-plugin-pkg": "^0.22.1",
    "prettier-plugin-prisma": "^5.0.0",
    "prettier-plugin-sh": "^0.18.0",
    "prettier-plugin-tailwindcss": "^0.8.0",
    "prettier-plugin-toml": "^2.0.6"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^26.1.0",
    "bun-osv-scanner": "^2.0.0",
    "lefthook": "^2.1.9",
    "prettier": "^3.9.4",
    "tsdown": "^0.22.3",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  }
}
